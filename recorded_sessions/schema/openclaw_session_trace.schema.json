{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw_session_trace.schema.json",
  "title": "OpenClaw Session Trace Export",
  "description": "Normalized export from OpenClaw session traces used to build recorded-session fixtures.",
  "type": "object",
  "required": [
    "trace_version",
    "trace_id",
    "source",
    "session_context",
    "prompt_template",
    "budgets",
    "turns",
    "redaction"
  ],
  "additionalProperties": false,
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "available_document": {
      "type": "object",
      "required": ["doc_id"],
      "properties": {
        "doc_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9._:-]+$"
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "metadata": {
          "type": "object"
        },
        "redacted": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["content"] },
        { "required": ["excerpt"] },
        { "required": ["content_sha256"] }
      ]
    }
  },
  "properties": {
    "trace_version": {
      "type": "string",
      "const": "openclaw_session_trace.v1"
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": ["product_version", "capture_date", "exported_at"],
      "properties": {
        "product_version": {
          "type": "string",
          "minLength": 1
        },
        "tenant_anon_id": {
          "type": "string"
        },
        "session_anon_id": {
          "type": "string"
        },
        "capture_date": {
          "type": "string",
          "format": "date"
        },
        "capture_timezone": {
          "type": "string"
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "session_context": {
      "type": "object",
      "required": ["matter_type"],
      "properties": {
        "matter_type": {
          "type": "string",
          "minLength": 1
        },
        "workspace_config": {
          "type": "object"
        },
        "user_role": {
          "type": "string"
        },
        "region": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "prompt_template": {
      "type": "object",
      "required": ["template_id", "template_sha256"],
      "properties": {
        "template_id": {
          "type": "string",
          "minLength": 1
        },
        "template_sha256": {
          "$ref": "#/$defs/sha256"
        }
      },
      "additionalProperties": false
    },
    "budgets": {
      "type": "object",
      "required": ["context_budget_tokens", "correction_budget"],
      "properties": {
        "context_budget_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "correction_budget": {
          "type": "integer",
          "minimum": 0
        },
        "teacher_delay": {
          "type": "integer",
          "minimum": 0
        },
        "random_seed": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["turn_id", "user_input", "assistant_output", "available_documents"],
        "properties": {
          "turn_id": {
            "type": "integer",
            "minimum": 0
          },
          "user_input": {
            "type": "string",
            "minLength": 1
          },
          "assistant_output": {
            "type": "string",
            "minLength": 1
          },
          "expected_output": {
            "type": "string",
            "minLength": 1
          },
          "rubric": {
            "type": "object",
            "properties": {
              "accept_criteria": {
                "type": "string"
              },
              "key_entities": {
                "type": "array",
                "items": { "type": "string" },
                "uniqueItems": true
              },
              "partial_credit": {
                "type": "boolean"
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "available_documents": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/available_document"
            }
          },
          "graph_snapshot": {
            "oneOf": [
              { "type": "null" },
              { "type": "object" }
            ]
          },
          "event_ids": {
            "type": "object",
            "properties": {
              "user": { "type": "string" },
              "assistant": { "type": "string" },
              "documents": { "type": "string" }
            },
            "additionalProperties": false
          },
          "annotations": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "redaction": {
      "type": "object",
      "required": ["redacted", "strategy"],
      "properties": {
        "redacted": {
          "type": "boolean"
        },
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "pii_classes_removed": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "person_name",
              "email",
              "phone",
              "address",
              "account_number",
              "organization_name",
              "other"
            ]
          },
          "uniqueItems": true
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
